---
interface Props {
  name: string;
  price: string;
  description?: string;
  tag?: string;
}

const { name, price, description, tag } = Astro.props;
---

<div class="group border border-border p-6 hover:border-accent/30 transition-all duration-500">
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-serif text-lg tracking-[0.1em]">{name}</h3>
    <span class="font-display text-accent text-sm tracking-[0.1em] shrink-0 ml-4">{price}</span>
  </div>
  {tag && (
    <span class="inline-block text-xs tracking-[0.15em] text-accent border border-accent/30 px-2 py-0.5 mb-3">
      {tag}
    </span>
  )}
  {description && (
    <p class="text-sm text-text-muted leading-relaxed">{description}</p>
  )}
</div>
