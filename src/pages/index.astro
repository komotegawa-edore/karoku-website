---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MenuCard from '../components/MenuCard.astro';
---

<Layout>
  <!-- Hero -->
  <Hero />

  <!-- Concept -->
  <section id="concept" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Concept</p>
        <h2 class="section-heading">こだわり</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/food/mentaiko-gohan.jpg" alt="奈良の美味しいお米" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">奈良の美味しいお米</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              奈良県産のこだわりのお米を使用。ふっくらと炊き上げたご飯は、定食の主役です。
            </p>
          </div>
        </div>

        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/drink/nara-sake.jpg" alt="厳選の日本酒" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">厳選の日本酒</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              奈良の地酒を中心に、料理に合う日本酒を厳選。セルフ飲み放題で心ゆくまでお楽しみください。
            </p>
          </div>
        </div>

        <div class="border border-border fade-in overflow-hidden">
          <div class="aspect-[4/3] overflow-hidden">
            <img src="/images/food/chicken-nanban.jpg" alt="手作りの味" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="text-center p-8">
            <h3 class="font-serif text-lg tracking-[0.1em] mb-4">手作りの味</h3>
            <p class="text-sm text-text-muted leading-relaxed">
              チキン南蛮の自家製タルタルソース、手作りハンバーグなど、一つひとつ丁寧に仕上げています。
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature: Self Drink -->
  <section class="py-24 px-6 bg-bg-light">
    <div class="max-w-5xl mx-auto fade-in">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/images/drink/self-nomihoudai.jpg" alt="セルフ飲み放題" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="text-center md:text-left">
          <p class="section-title">Self Drink</p>
          <h2 class="section-heading mb-6">セルフ飲み放題</h2>
          <div class="divider md:mx-0 mx-auto"></div>
          <p class="text-4xl font-serif text-accent mt-8 mb-2 tracking-[0.1em]">
            60<span class="text-lg">分</span> &yen;1,800
          </p>
          <p class="text-sm text-text-muted leading-relaxed mt-4">
            生ビール、日本酒、ハイボール、サワー、果実酒など豊富なラインナップ。<br />
            お好きなタイミングで、お好きなだけお楽しみいただけます。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Preview -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Menu</p>
        <h2 class="section-heading">おすすめ料理</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 fade-in">
        <MenuCard
          name="チキン南蛮定食"
          price="¥1,000"
          description="たまごたっぷりの自家製タルタルソースが自慢の看板メニュー"
          tag="人気No.1"
          image="/images/food/chicken-nanban-teishoku.jpg"
        />
        <MenuCard
          name="厚切り牛ハラミ"
          price="¥1,300"
          description="一枚一枚、手切りにこだわった厚切りハラミ。食べ応え抜群"
          tag="絶品"
          image="/images/food/atsugiri-harami.jpg"
        />
        <MenuCard
          name="手作りハンバーグ"
          price="¥1,000"
          description="手作りにこだわったジューシーな牛肉100%ハンバーグ"
          image="/images/food/hamburger.jpg"
        />
        <MenuCard
          name="トンネギ"
          price="¥800"
          description="華鹿オリジナル。豚バラ肉に鬼おろしとネギとポン酢であっさり"
          image="/images/food/tonnegi.jpg"
        />
      </div>

      <div class="text-center mt-12 fade-in">
        <a href="/menu" class="btn-outline">
          メニューをすべて見る →
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="py-24 px-6 bg-bg-light">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Gallery</p>
        <h2 class="section-heading">ギャラリー</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 fade-in">
        <div class="aspect-square overflow-hidden">
          <img src="/images/food/food-and-drink.jpg" alt="こだわり料理とセルフ飲み放題" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/food/chicken-nanban-2.jpg" alt="チキン南蛮" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/drink/drink-bar.jpg" alt="セルフ飲み放題ドリンクバー" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/atmosphere/zashiki.jpg" alt="座敷席" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/food/teppan-napolitan.jpg" alt="鉄板ナポリタン" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
        <div class="aspect-square overflow-hidden">
          <img src="/images/drink/nihonshu.jpg" alt="日本酒" class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 fade-in">
        <p class="section-title">Information</p>
        <h2 class="section-heading">店舗情報</h2>
        <div class="divider mx-auto"></div>
      </div>

      <div class="border border-border fade-in">
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">住所</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            奈良県奈良市上三条町7番地 イノウエビル2F
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">電話番号</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            <a href="tel:050-8887-3987" class="hover:text-accent transition-colors">050-8887-3987</a>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">営業時間</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            <p>月〜土 11:30〜14:00 / 17:00〜21:00</p>
            <p>日・祝 11:30〜14:00</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] border-b border-border">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">定休日</div>
          <div class="px-6 py-4 text-sm text-text-muted">不定休</div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-[140px_1fr]">
          <div class="bg-bg-light px-6 py-4 font-serif text-sm tracking-[0.1em]">席数</div>
          <div class="px-6 py-4 text-sm text-text-muted">
            22席（座敷最大10名 / テーブル席6名 / カウンター席6名）
          </div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-12 fade-in">
        <a href="tel:050-8887-3987" class="btn-primary justify-center">
          電話で予約
        </a>
        <a href="/access" class="btn-outline justify-center">
          アクセスを見る
        </a>
      </div>
    </div>
  </section>
</Layout>
